# ===== Database =====
DATABASE_URL=postgresql://user:password@localhost:5432/restaurant
DATABASE_URL_POOL_MAX=10

# ===== App =====
APP_NAME=restaurant
APP_DESCRIPTION="Restaurant API"
APP_PORT=3052
NODE_ENV=development

# ===== Auth =====
AUTH_ACCESS_TOKEN_SECRET=your_access_token_secret_123456
AUTH_REFRESH_TOKEN_SECRET=your_refresh_token_secret_123456
AUTH_ACCESS_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_TOKEN_EXPIRES_IN=7d

# ===== Admin seed =====
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpassword
ADMIN_PHONE_NUMBER=0123456789

# ===== OTP & Email =====
OTP_EXPIRES_IN=5m
RESEND_API_KEY=re_your_resend_api_key

# ===== Google OAuth =====
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3052/api/auth/google/callback
GOOGLE_CLIENT_REDIRECT_URI=http://localhost:3000

# ===== Cloudinary =====
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_cloud_api_key
CLOUD_API_SECRET=your_cloud_api_secret
CLOUD_URL=cloudinary://api_key:api_secret@cloud_name

# ===== Firebase =====
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# ===== Throttle =====
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# ===== Other =====
SECRET_API_KEY=your_secret_api_key
JWT_SECRET=your_jwt_secret
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ===== MoMo =====
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_IPN_URL=https://yourdomain.com/api/payment/momo/ipn
MOMO_REDIRECT_URL=https://yourdomain.com/payment/result
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# ===== AI =====
GEMINI_API_KEY=your_gemini_api_key
